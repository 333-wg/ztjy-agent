# 应用基础配置
# APP_NAME：服务显示名称
APP_NAME=Advertisement Agent System
# APP_ENV：运行环境，常用 development / staging / production
APP_ENV=development

# Supabase 配置
# SUPABASE_URL：Supabase 项目地址
SUPABASE_URL=
# SUPABASE_ANON_KEY：前端可用的匿名 key
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY：后端专用密钥，不要暴露给前端
SUPABASE_SERVICE_ROLE_KEY=

# 公司管理后台与浏览器配置
# ADMIN_BACKEND_URL：公司管理系统后台地址
ADMIN_BACKEND_URL=
# BROWSER_PROFILE_PATH：浏览器用户数据目录，用于保留登录状态
BROWSER_PROFILE_PATH=
# BROWSER_PROFILE_ALIAS：浏览器配置别名，方便区分测试/生产账号
BROWSER_PROFILE_ALIAS=
# PLAYWRIGHT_LOGIN_SUCCESS_SELECTOR：判断后台已登录成功的页面选择器
PLAYWRIGHT_LOGIN_SUCCESS_SELECTOR=

# LangGraph 持久化配置
# LANGGRAPH_CHECKPOINTER：memory 本地内存；postgres 使用 Supabase Postgres；none 关闭
LANGGRAPH_CHECKPOINTER=memory
# LANGGRAPH_POSTGRES_URL：Supabase Postgres 连接串，不是 SUPABASE_URL
LANGGRAPH_POSTGRES_URL=
# LANGGRAPH_POSTGRES_SETUP：首次创建 checkpoint 表时才设为 true
LANGGRAPH_POSTGRES_SETUP=false

# 大模型命令解析配置
# LLM_PARSER_MODE：deterministic 规则解析；hybrid 规则优先再用模型；llm 全部用模型
LLM_PARSER_MODE=deterministic
# LLM_PROVIDER：默认 none；启用模型时使用 openai_compatible
LLM_PROVIDER=none
# LLM_API_KEY：大模型 API Key，只放本地 .env，不要提交真实 key
LLM_API_KEY=
# LLM_BASE_URL：OpenAI 或兼容网关地址
LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL：模型名称，例如 gpt-4.1-mini 或你的私有模型名
LLM_MODEL=
# LLM_TEMPERATURE：命令解析建议保持 0，输出更稳定
LLM_TEMPERATURE=0
# LLM_TIMEOUT_SECONDS：模型请求超时时间
LLM_TIMEOUT_SECONDS=30
